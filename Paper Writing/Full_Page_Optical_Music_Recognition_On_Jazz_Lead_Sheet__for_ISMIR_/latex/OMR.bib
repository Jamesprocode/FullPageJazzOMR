	shorttitle = {From Optical Music Recognition to Handwritten Music Recognition},
	abstract = {Optical Music Recognition ({OMR}) is the branch of document image analysis that aims to convert images of musical scores into a computer-readable format. Despite decades of research, the recognition of handwritten music scores, concretely the Western notation, is still an open problem, and the few existing works only focus on a speciﬁc stage of {OMR}. In this work, we propose a full Handwritten Music Recognition ({HMR}) system based on Convolutional Recurrent Neural Networks, data augmentation and transfer learning, that can serve as a baseline for the research community.},
	pages = {1--8},
	journaltitle = {Pattern Recognition Letters},
